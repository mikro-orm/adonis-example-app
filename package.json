{
  "name": "@mikro-orm/adonis-example-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MikroORM example app with AdonisJS",
  "repository": "https://github.com/mikro-orm/adonis-example-app",
  "author": "Martin Adamek",
  "license": "MIT",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#entities/*": "./app/entities/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#repositories/*": "./app/repositories/*.js",
    "#services/*": "./app/services/*.js",
    "#subscribers/*": "./app/subscribers/*.js",
    "#providers/*": "./providers/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#tests/*": "./tests/*.js"
  },
  "dependencies": {
    "@adonisjs/core": "^7.0.1",
    "@mikro-orm/core": "^7.0.1",
    "@mikro-orm/migrations": "^7.0.1",
    "@mikro-orm/sqlite": "^7.0.1",
    "argon2": "^0.44.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.1",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@mikro-orm/cli": "^7.0.1",
    "@mikro-orm/seeder": "^7.0.1",
    "@poppinss/ts-exec": "^1.0.0",
    "@types/node": "^25.5.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./mikro-orm.config.ts"
    ]
  }
}
